pipeline {
    agent any  {
        node {label 'node1'}
    }
    stages {
        stage('pull') {
            steps {
                 git branch: 'main', url: 'https://github.com/aartikale427-lgtm/StudentData.git'
                echo "pulling code"
            }
        }
        stage('Build') {
            steps {
                echo "building code"
            }
        }
        stage('Test') {
            steps {
                echo "testing code"
            }
        }
        stage('Deploy') {
            steps {
                echo "deploying code"
            }
        }
    }
}